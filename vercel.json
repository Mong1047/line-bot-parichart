{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/webhook",
      "dest": "/api/index.py",
      "methods": ["POST"]
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}